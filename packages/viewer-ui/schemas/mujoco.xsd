                  </xs:attribute>
                  <xs:attribute name="kv" type="xs:double" default="1">
                    <xs:annotation>
                      <xs:documentation>Velocity feedback gain.</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                </xs:complexType>
