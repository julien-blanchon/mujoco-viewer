                      <xs:documentation>Color of slider-crank mechanisms.</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                  <xs:attribute name="crankbroken" type="list_real_4" default="0.9 0 0 1">
                    <xs:annotation>
                      <xs:documentation>Color used to render the crank of slide-crank mechanisms, in model configurations where the specified rod length
cannot be maintained, i.e., it is "broken".</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                  <xs:attribute name="frustum" type="list_real_4" default="1 1 0 0.2">
                    <xs:annotation>
                      <xs:documentation>Color used to render the camera frustum.</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                  <xs:attribute name="bv" type="list_real_4" default="0 1 0 0.5">
                    <xs:annotation>
                      <xs:documentation>Color used to render bounding volumes.</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                  <xs:attribute name="bvactive" type="list_real_4" default="1 0 0 0.5">
                    <xs:annotation>
                      <xs:documentation>Color used to render active bounding volumes, if the bvactive flag is "true".</xs:documentation>
                    </xs:annotation>
                  </xs:attribute>
                </xs:complexType>
