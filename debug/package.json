{
  "name": "mujoco-viewer-debug",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone web app that loads the same MuJoCo viewer UI as the VSCode extension, for faster iteration without a VSCode reload.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
