  },
  "dependencies": {
    "@mujoco-viewer/protocol": "workspace:*",
    "@mujoco-viewer/viewer-ui": "workspace:*",
    "mujoco-svelte": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@threlte/core": "^8.5.0",
    "@threlte/extras": "^9.3.0",
    "@types/three": "^0.181.0",
    "svelte": "^5.50.0",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^4.0.0",
    "three": "^0.181.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
